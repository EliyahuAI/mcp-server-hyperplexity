{
  "type": "object",
  "required": ["columns", "search_strategy", "table_name", "tablewide_research"],
  "properties": {
    "columns": {
      "type": "array",
      "description": "Array of column objects including ID and research columns",
      "items": {
        "type": "object",
        "required": ["name", "description", "format", "importance", "is_identification"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Column name"
          },
          "description": {
            "type": "string",
            "description": "Detailed description of what this column contains"
          },
          "format": {
            "type": "string",
            "description": "Data format (String, Number, Boolean, URL, Date, etc.)"
          },
          "importance": {
            "type": "string",
            "enum": ["ID", "CRITICAL"],
            "description": "Column importance level"
          },
          "is_identification": {
            "type": "boolean",
            "description": "Whether this column is used for row identification"
          },
          "validation_strategy": {
            "type": "string",
            "description": "How to validate this column's data (required for research columns)"
          }
        }
      }
    },
    "search_strategy": {
      "type": "object",
      "required": ["description", "subdomains"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Clear description of what entities to find"
        },
        "subdomains": {
          "type": "array",
          "description": "2-5 subdomains for parallel row discovery with search queries and targets",
          "minItems": 2,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["name", "focus", "search_queries", "target_rows"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Concise name for this subdomain",
                "minLength": 5
              },
              "focus": {
                "type": "string",
                "description": "Detailed description of this subdomain's focus area",
                "minLength": 10
              },
              "search_queries": {
                "type": "array",
                "description": "Search queries specific to this subdomain that yield MULTIPLE entities",
                "minItems": 2,
                "maxItems": 5,
                "items": {
                  "type": "string",
                  "minLength": 10
                }
              },
              "target_rows": {
                "type": "integer",
                "description": "Number of candidate rows to find for this subdomain",
                "minimum": 3
              }
            }
          }
        }
      }
    },
    "table_name": {
      "type": "string",
      "description": "Concise name for the table"
    },
    "tablewide_research": {
      "type": "string",
      "description": "Overall research context and objectives for this table"
    }
  }
}
