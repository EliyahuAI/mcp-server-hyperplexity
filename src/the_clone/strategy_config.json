{
  "default_model": "deepseek-v3.2",

  "strategies": {
    "targeted": {
      "description": "Narrow breadth + Shallow depth: Find specific fact or answer",
      "breadth": "narrow",
      "depth": "shallow",
      "sources_per_batch": 5,
      "extraction_mode": "simple_facts",
      "max_snippets_per_source": 2,
      "min_p_threshold": 0.85,
      "stop_condition": "reliable_answer_found",
      "max_tokens_per_page": 512,
      "batch_extraction": true
    },
    "focused_deep": {
      "description": "Narrow breadth + Deep depth: Detailed explanation of single topic",
      "breadth": "narrow",
      "depth": "deep",
      "sources_per_batch": 10,
      "extraction_mode": "nuanced",
      "max_snippets_per_source": 8,
      "min_p_threshold": 0.50,
      "stop_condition": null,
      "max_tokens_per_page": 2048,
      "batch_extraction": true
    },
    "survey": {
      "description": "Broad breadth + Shallow depth: List/enumerate many aspects",
      "breadth": "broad",
      "depth": "shallow",
      "sources_per_batch": 15,
      "extraction_mode": "simple_facts",
      "max_snippets_per_source": 3,
      "min_p_threshold": 0.65,
      "stop_condition": null,
      "max_tokens_per_page": 512,
      "batch_extraction": true
    },
    "comprehensive": {
      "description": "Broad breadth + Deep depth: Detailed analysis of many aspects",
      "breadth": "broad",
      "depth": "deep",
      "sources_per_batch": 15,
      "extraction_mode": "nuanced",
      "max_snippets_per_source": 10,
      "min_p_threshold": 0.50,
      "stop_condition": null,
      "max_tokens_per_page": 2048,
      "batch_extraction": true
    },
    "findall_breadth": {
      "description": "Maximum breadth: 3 searches × 15 results, batch extraction",
      "breadth": "findall",
      "depth": "shallow",
      "sources_per_batch": 15,
      "extraction_mode": "simple_facts",
      "max_snippets_per_source": 7,
      "min_p_threshold": 0.65,
      "accept_all_quality_levels": true,
      "stop_condition": null,
      "max_tokens_per_page": 512,
      "batch_extraction": true,
      "synthesis_model": "gemini-3-flash-preview",
      "max_results_per_search": 15,
      "bypass_global_source_limit": true
    },
    "extraction": {
      "description": "Structured data extraction: Deep content + parallel processing + Gemini 3 synthesis",
      "breadth": "narrow",
      "depth": "extraction",
      "sources_per_batch": 10,
      "extraction_mode": "structured",
      "max_snippets_per_source": 20,
      "min_p_threshold": 0.50,
      "stop_condition": null,
      "max_tokens_per_page": 8192,
      "batch_extraction": true,
      "use_search_api": true,
      "synthesis_model": "gemini-3-flash-preview",
      "parallel_extraction": true,
      "max_results_per_search": 10
    }
  },

  "global_limits": {
    "max_iterations": 4,
    "max_sources_total": 40,
    "max_search_terms": 3
  },

  "providers": {
    "deepseek": {
      "description": "Default provider using Gemini 2.5 Flash Lite for extraction, DeepSeek for synthesis",
      "default_extraction_model": "gemini-2.5-flash-lite",
      "tiers": {
        "tier1": {
          "synthesis": "gemini-2.5-flash-lite",
          "label": "Fast",
          "description": "Fast, cost-effective synthesis for simple queries"
        },
        "tier2": {
          "synthesis": "deepseek-v3.2",
          "label": "Balanced",
          "description": "Balanced synthesis with DeepSeek → Sonnet → Opus fallback chain"
        },
        "tier3": {
          "synthesis": "claude-sonnet-4-5",
          "label": "Strong",
          "description": "Explicit upgrade to Claude Sonnet for complex reasoning"
        },
        "tier4": {
          "synthesis": "claude-opus-4-6",
          "label": "Deepest",
          "description": "Maximum capability - Opus for hardest problems (auto-upgrade tier)"
        }
      }
    },
    "claude": {
      "description": "Gemini extraction + Claude synthesis for speed and reliability",
      "default_extraction_model": "gemini-2.5-flash-lite",
      "tiers": {
        "tier1": {
          "synthesis": "claude-haiku-4-5",
          "label": "Fast",
          "description": "Fast synthesis for simple queries"
        },
        "tier2": {
          "synthesis": "claude-sonnet-4-5",
          "label": "Balanced",
          "description": "Balanced performance for typical queries"
        },
        "tier3": {
          "synthesis": "claude-sonnet-4-5",
          "label": "Strong",
          "description": "Strong reasoning for complex queries"
        },
        "tier4": {
          "synthesis": "claude-opus-4-6",
          "label": "Deepest",
          "description": "Deepest analysis for hardest problems"
        }
      }
    },
    "baseten": {
      "description": "Gemini extraction + Baseten DeepSeek synthesis for speed",
      "default_extraction_model": "gemini-2.5-flash-lite",
      "tiers": {
        "tier1": {
          "synthesis": "deepseek-v3.2-baseten",
          "label": "Fast",
          "description": "Fast, cost-effective synthesis via Baseten"
        },
        "tier2": {
          "synthesis": "deepseek-v3.2-baseten",
          "label": "Balanced",
          "description": "Balanced performance via Baseten"
        },
        "tier3": {
          "synthesis": "claude-sonnet-4-5",
          "label": "Strong",
          "description": "Strong reasoning for complex queries"
        },
        "tier4": {
          "synthesis": "claude-opus-4-6",
          "label": "Deepest",
          "description": "Deepest analysis for hardest problems"
        }
      }
    },
    "kimi": {
      "description": "Gemini extraction + Kimi K2.5 synthesis via OpenRouter",
      "default_extraction_model": "gemini-2.5-flash-lite",
      "tiers": {
        "tier1": {
          "synthesis": "moonshotai/kimi-k2.5",
          "label": "Fast",
          "description": "Fast synthesis via Kimi K2.5 (OpenRouter)"
        },
        "tier2": {
          "synthesis": "moonshotai/kimi-k2.5",
          "label": "Balanced",
          "description": "Balanced performance via Kimi K2.5 (OpenRouter)"
        },
        "tier3": {
          "synthesis": "claude-sonnet-4-6",
          "label": "Strong",
          "description": "Strong reasoning - falls back to Claude Sonnet"
        },
        "tier4": {
          "synthesis": "claude-opus-4-6",
          "label": "Deepest",
          "description": "Deepest analysis - falls back to Claude Opus"
        }
      }
    },
    "flash": {
      "description": "Gemini 3 Flash (Google AI Studio) synthesis — high thinking, web-grounded via Perplexity",
      "default_extraction_model": "gemini-2.5-flash-lite",
      "tiers": {
        "tier1": {
          "synthesis": "gemini-3-flash-preview-low",
          "label": "Fast",
          "description": "Fast synthesis via Gemini 3 Flash low-thinking (AI Studio → OpenRouter)"
        },
        "tier2": {
          "synthesis": "gemini-3-flash-preview",
          "label": "Balanced",
          "description": "Medium-thinking synthesis via Gemini 3 Flash (AI Studio → OpenRouter)"
        },
        "tier3": {
          "synthesis": "claude-sonnet-4-6",
          "label": "Strong",
          "description": "Strong reasoning fallback via Claude Sonnet"
        },
        "tier4": {
          "synthesis": "claude-opus-4-6",
          "label": "Deepest",
          "description": "Maximum capability fallback via Claude Opus"
        }
      }
    }
  }
}
