{
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["pass", "filter", "retrigger_discovery", "restructure"],
      "description": "QC decision: pass=approve all as-is, filter=remove some rows, retrigger_discovery=need more rows, restructure=0 rows need table redesign"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "action": { "const": "pass" } }
      },
      "then": {
        "required": ["action", "rows", "overall_score"],
        "properties": {
          "rows": {
            "type": "array",
            "description": "All rows in priority order (best first)",
            "items": { "type": "object" }
          },
          "overall_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Overall quality score for the set"
          }
        }
      }
    },
    {
      "if": {
        "properties": { "action": { "const": "filter" } }
      },
      "then": {
        "required": ["action", "rows", "removed", "overall_score"],
        "properties": {
          "rows": {
            "type": "array",
            "description": "Approved rows in priority order (best first)",
            "items": { "type": "object" }
          },
          "removed": {
            "type": "array",
            "description": "Removed rows with explanations",
            "items": {
              "type": "object",
              "required": ["row_id", "reason"],
              "properties": {
                "row_id": { "type": "string" },
                "reason": { "type": "string", "description": "1 sentence why removed" }
              }
            }
          },
          "overall_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": { "action": { "const": "retrigger_discovery" } }
      },
      "then": {
        "required": ["action", "rows", "discovery_guidance", "new_subdomains", "overall_score"],
        "properties": {
          "rows": {
            "type": "array",
            "description": "Current approved rows",
            "items": { "type": "object" }
          },
          "discovery_guidance": {
            "type": "string",
            "description": "What discovery needs to find (focus on MORE ROWS, not filling columns)"
          },
          "new_subdomains": {
            "type": "array",
            "description": "New search subdomains to find more entities",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "focus", "search_queries", "target_rows"],
              "properties": {
                "name": { "type": "string" },
                "focus": { "type": "string" },
                "search_queries": {
                  "type": "array",
                  "items": { "type": "string" },
                  "minItems": 2
                },
                "target_rows": { "type": "integer", "minimum": 1 }
              }
            }
          },
          "overall_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": { "action": { "const": "restructure" } }
      },
      "then": {
        "required": ["action", "restructuring_guidance", "user_message"],
        "properties": {
          "restructuring_guidance": {
            "type": "object",
            "required": ["column_changes", "requirement_changes", "search_broadening"],
            "properties": {
              "column_changes": { "type": "string" },
              "requirement_changes": { "type": "string" },
              "search_broadening": { "type": "string" }
            }
          },
          "user_message": {
            "type": "string",
            "description": "User-facing message explaining the restructure"
          }
        }
      }
    }
  ]
}
