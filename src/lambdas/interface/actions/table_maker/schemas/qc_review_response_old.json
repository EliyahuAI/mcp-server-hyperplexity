{
  "type": "object",
  "required": [],
  "properties": {
    "reviewed_rows": {
      "type": "array",
      "description": "All rows after QC review with keep/reject decisions",
      "items": {
        "type": "object",
        "required": ["row_id", "row_score", "qc_score", "keep"],
        "properties": {
          "row_id": {
            "type": "string",
            "description": "Row identifier: row number + first ID column value (e.g., '1-Benchling')"
          },
          "row_score": {
            "type": "number",
            "description": "Original discovery score (copied from input)"
          },
          "qc_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "QC assessment score - more flexible than discovery rubric"
          },
          "qc_rationale": {
            "type": "string",
            "description": "1-2 sentence explanation of QC decision"
          },
          "keep": {
            "type": "boolean",
            "description": "Whether to include this row in final table"
          },
          "priority_adjustment": {
            "type": "string",
            "enum": ["promote", "demote", "none"],
            "description": "Whether to adjust priority vs discovery ranking"
          }
        }
      }
    },
    "rejected_rows": {
      "type": "array",
      "description": "Rows that were rejected (keep=false)",
      "items": {
        "type": "object",
        "required": ["row_id", "rejection_reason"],
        "properties": {
          "row_id": {
            "type": "string",
            "description": "Row identifier: row number + first ID column value"
          },
          "rejection_reason": {
            "type": "string",
            "description": "1-2 sentence explanation of why row was rejected"
          }
        }
      }
    },
    "qc_summary": {
      "type": "object",
      "required": ["total_reviewed", "kept", "rejected"],
      "properties": {
        "total_reviewed": {
          "type": "integer",
          "description": "Total number of rows reviewed"
        },
        "kept": {
          "type": "integer",
          "description": "Number of rows marked keep=true"
        },
        "rejected": {
          "type": "integer",
          "description": "Number of rows marked keep=false"
        },
        "promoted": {
          "type": "integer",
          "description": "Number of rows with priority_adjustment=promote"
        },
        "demoted": {
          "type": "integer",
          "description": "Number of rows with priority_adjustment=demote"
        },
        "reasoning": {
          "type": "string",
          "description": "Overall summary of QC decisions (1-2 sentences)"
        },
        "minimum_guarantee_applied": {
          "type": "boolean",
          "description": "Whether rejected rows were promoted to meet minimum row count"
        },
        "insufficient_rows": {
          "type": "boolean",
          "description": "Whether total discovered rows were below minimum threshold"
        }
      }
    },
    "insufficient_rows_statement": {
      "type": "string",
      "description": "Optional: Overall assessment of why so few results were discovered (only if insufficient_rows=true)"
    },
    "insufficient_rows_recommendations": {
      "type": "array",
      "description": "Optional: Recommendations for improving results (only if insufficient_rows=true)",
      "items": {
        "type": "object",
        "required": ["type", "recommendation"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["search_broadening", "table_restructuring", "criteria_adjustment"],
            "description": "Type of recommendation: search_broadening (adjust request wording), table_restructuring (change columns), or criteria_adjustment (relax requirements)"
          },
          "issue": {
            "type": "string",
            "description": "The problem identified"
          },
          "recommendation": {
            "type": "string",
            "description": "How to address it"
          }
        }
      }
    },
    "recovery_decision": {
      "type": "object",
      "description": "REQUIRED when 0 rows approved: Autonomous decision on whether to restructure or give up",
      "required": ["decision", "reasoning"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["restructure", "give_up"],
          "description": "restructure = can fix with column/requirement changes, give_up = fundamentally impossible"
        },
        "reasoning": {
          "type": "string",
          "description": "2-3 sentences explaining why you chose this decision"
        },
        "restructuring_guidance": {
          "type": "object",
          "description": "Required if decision=restructure. Instructions for how to restructure the table.",
          "properties": {
            "column_changes": {
              "type": "string",
              "description": "Specific instructions for column generator to restructure columns"
            },
            "requirement_changes": {
              "type": "string",
              "description": "How to adjust hard/soft requirements"
            },
            "search_broadening": {
              "type": "string",
              "description": "How to expand search strategy/domains"
            }
          }
        },
        "fundamental_problem": {
          "type": "string",
          "description": "Required if decision=give_up. Specific issue that makes this impossible."
        },
        "user_facing_message": {
          "type": "string",
          "description": "Required if decision=restructure. Message shown to user during automatic restructure."
        },
        "user_facing_apology": {
          "type": "string",
          "description": "Required if decision=give_up. Apology message explaining why it's impossible."
        }
      }
    },
    "retrigger_discovery": {
      "type": "object",
      "description": "Optional: Request to retrigger discovery with new strategy",
      "properties": {
        "should_retrigger": {
          "type": "boolean",
          "description": "Whether to retrigger discovery"
        },
        "reason": {
          "type": "string",
          "description": "Why retrigger is needed"
        },
        "new_subdomains": {
          "type": "array",
          "description": "Completely new subdomain definitions (de-novo, not modifications)",
          "items": {
            "type": "object",
            "required": ["name", "focus", "search_queries", "target_rows"],
            "properties": {
              "name": {
                "type": "string",
                "description": "New subdomain name"
              },
              "focus": {
                "type": "string",
                "description": "What to search for"
              },
              "search_queries": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "target_rows": {
                "type": "integer",
                "minimum": 1
              },
              "included_domains": {
                "type": "array",
                "description": "Optional: Override included domains",
                "items": {
                  "type": "string"
                }
              },
              "excluded_domains": {
                "type": "array",
                "description": "Optional: Override excluded domains",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "updated_requirements": {
          "type": "array",
          "description": "Optional: Updated requirements (can relax/tighten)",
          "items": {
            "type": "object",
            "required": ["requirement", "type", "rationale"],
            "properties": {
              "requirement": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": ["hard", "soft"]
              },
              "rationale": {
                "type": "string",
                "description": "Why this change"
              }
            }
          }
        },
        "updated_default_domains": {
          "type": "object",
          "description": "Optional: Updated default domain filtering",
          "properties": {
            "included_domains": {
              "type": "array",
              "description": "Add or replace included domains",
              "items": {
                "type": "string"
              }
            },
            "excluded_domains": {
              "type": "array",
              "description": "Add or replace excluded domains",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
